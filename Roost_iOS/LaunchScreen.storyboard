        </namedColor>
        <!-- Off-white at 45% for muted studio credit -->
        <namedColor name="LaunchMuted">
            <color colorSpace="custom" customColorSpace="sRGB" red="0.94902" green="0.92157" blue="0.87843" alpha="0.45" cocoaTouchSystemColor="no"/>
