    <resources>
        <image name="RoostIconRounded" width="60" height="60"/>
        <!-- Deep warm charcoal — mirrors auth screen dark background (#0F0D0B) -->
        <namedColor name="LaunchBackground">
            <color colorSpace="custom" customColorSpace="sRGB" red="0.05882" green="0.05098" blue="0.04314" alpha="1" cocoaTouchSystemColor="no"/>
