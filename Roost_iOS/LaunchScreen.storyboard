<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard.XIB" version="3.0" toolsVersion="13122.16" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" launchScreen="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES" initialViewController="01J-lp-oVM">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="13104.12"/>
        <capability name="Named colors" minToolsVersion="9.0"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <scenes>
        <scene sceneID="EHf-IW-A2E">
            <objects>
                <viewController id="01J-lp-oVM" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="Ze5-6b-2t3">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <!-- App icon — rounded variant, 104 × 104 -->
                            <imageView opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="scaleAspectFit" image="RoostIconRounded" translatesAutoresizingMaskIntoConstraints="NO" id="Img-IC-on">
                                <constraints>
                                    <constraint firstAttribute="width" constant="104" id="wic-104"/>
                                    <constraint firstAttribute="height" constant="104" id="hic-104"/>
                                </constraints>
                            </imageView>
                            <!-- App name -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Roost" textAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="Lbl-RS-t1">
                                <fontDescription type="system" weight="semibold" pointSize="32"/>
                                <color key="textColor" name="LaunchForeground"/>
                            </label>
                            <!-- Studio credit -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Pinehollow Studios" textAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="Lbl-PH-h1">
                                <fontDescription type="system" weight="medium" pointSize="11"/>
                                <color key="textColor" name="LaunchMuted"/>
                            </label>
                        </subviews>
                        <color key="backgroundColor" name="LaunchBackground"/>
                        <constraints>
                            <!-- Icon: centred horizontally, 64pt above vertical centre -->
                            <constraint firstItem="Img-IC-on" firstAttribute="centerX" secondItem="Ze5-6b-2t3" secondAttribute="centerX" id="cxIcon"/>
                            <constraint firstItem="Img-IC-on" firstAttribute="centerY" secondItem="Ze5-6b-2t3" secondAttribute="centerY" constant="-64" id="cyIcon"/>
                            <!-- "Roost" label: centred, 22pt below icon -->
                            <constraint firstItem="Lbl-RS-t1" firstAttribute="centerX" secondItem="Ze5-6b-2t3" secondAttribute="centerX" id="cxLabel"/>
                            <constraint firstItem="Lbl-RS-t1" firstAttribute="top" secondItem="Img-IC-on" secondAttribute="bottom" constant="22" id="iconToLabel"/>
                            <!-- Studio credit: centred, 32pt above safe-area bottom -->
                            <constraint firstItem="Lbl-PH-h1" firstAttribute="centerX" secondItem="Ze5-6b-2t3" secondAttribute="centerX" id="cxPH"/>
                            <constraint firstItem="6Tk-OE-BBY" firstAttribute="bottom" secondItem="Lbl-PH-h1" secondAttribute="bottom" constant="32" id="botPH"/>
